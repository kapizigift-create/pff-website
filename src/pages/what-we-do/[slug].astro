---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const programs = await getCollection('programs');
  return programs.map((program) => ({
    params: { slug: program.id },
    props: { program },
  }));
}

const { program } = Astro.props;
const { Content } = await render(program);
---

<BaseLayout title={program.data.name} description={program.data.tagline}>

  <section class="page-header">
    <div class="container">
      <h1>{program.data.name}</h1>
      <p>{program.data.tagline}</p>
    </div>
  </section>

  <section class="section">
    <div class="container program-detail">
      <div class="program-hero-img">
        {program.data.image ? <img src={program.data.image} alt={program.data.name} /> : <span>Image: {program.data.name}</span>}
      </div>
      <div class="program-body">
        <p class="program-intro">{program.data.description}</p>
        <div class="program-content">
          <Content />
        </div>

        {!program.data.active && (
          <div class="completed-notice">
            <strong>🏁 This program has been completed.</strong> Its impact continues to benefit the communities we served.
            <div style="margin-top: 1rem;">
              <a href="/what-we-do">← Back to All Programs</a>
            </div>
          </div>
        )}

        {program.data.active && (
          <div style="margin-top: 2rem;">
            <a href="/what-we-do">← Back to All Programs</a>
          </div>
        )}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .program-detail {
    max-width: 800px;
    margin: 0 auto;
  }
  .program-hero-img {
    width: 100%;
    height: 350px;
    background: var(--color-gray-light);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--color-gray);
    margin-bottom: 2rem;
    overflow: hidden;
  }
  .program-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .program-hero-img span {
    color: var(--color-gray);
    font-size: 0.9rem;
  }
  .program-intro {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    color: var(--color-navy);
  }
  .program-content :global(h2) {
    margin: 2rem 0 0.8rem;
    color: var(--color-navy);
  }
  .program-content :global(h3) {
    margin: 1.5rem 0 0.5rem;
    color: var(--color-gold);
  }
  .program-content :global(p) {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .program-content :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .program-content :global(li) {
    margin-bottom: 0.4rem;
    font-size: 1.05rem;
  }
  .program-content :global(strong) {
    color: var(--color-navy);
  }
  .completed-notice {
    background: var(--color-off-white);
    border-left: 4px solid var(--color-navy);
    padding: 1.5rem;
    border-radius: 0 8px 8px 0;
    margin-top: 2rem;
  }
  @media (max-width: 600px) {
    .program-hero-img {
      height: 220px;
    }
  }
</style>