---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPrograms = await getCollection('programs');
allPrograms.sort((a, b) => a.data.order - b.data.order);
const activePrograms = allPrograms.filter((p) => p.data.active !== false);
const pastPrograms = allPrograms.filter((p) => p.data.active === false);
---

<BaseLayout title="What We Do" description="Our programs empower vulnerable communities across Malawi through education, hygiene, and sustainable livelihoods.">

  <section class="page-header">
    <div class="container">
      <h1>What We Do</h1>
      <p>People-centered programs that restore dignity and build self-reliance</p>
    </div>
  </section>

  <!-- Active Programs -->
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 2rem;">Current Programs</h2>
      <div class="program-list">
        {activePrograms.map((program) => (
          <div class="program-row">
            <div class="program-img-placeholder">
              {program.data.image ? <img src={program.data.image} alt={program.data.name} /> : `Image: ${program.data.name}`}
            </div>
            <div>
              <h3>{program.data.name}</h3>
              <p>{program.data.description}</p>
              <a href={`/what-we-do/${program.id}`} class="btn btn-secondary">Learn More</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Past Programs -->
  {pastPrograms.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <h2 style="margin-bottom: 2rem;">Past Programs</h2>
        <p style="margin-bottom: 2rem; color: var(--color-gray);">Programs we've successfully completed. Their impact lives on in the communities we served.</p>
        <div class="program-list">
          {pastPrograms.map((program) => (
            <div class="program-row past-program">
              <div class="program-img-placeholder">
                {program.data.image ? <img src={program.data.image} alt={program.data.name} /> : `Image: ${program.data.name}`}
              </div>
              <div>
                <h3>{program.data.name} <span class="completed-badge">Completed</span></h3>
                <p>{program.data.description}</p>
                <a href={`/what-we-do/${program.id}`} class="btn btn-secondary">View Details</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .program-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .program-row {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 2rem;
    align-items: center;
  }
  .program-img-placeholder {
    height: 220px;
    background: var(--color-gray-light);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--color-gray);
    font-size: 0.85rem;
    overflow: hidden;
  }
  .program-img-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .program-row h3 {
    margin-bottom: 0.5rem;
  }
  .program-row p {
    margin-bottom: 1rem;
    color: #444;
  }
  .completed-badge {
    display: inline-block;
    background: var(--color-navy);
    color: white;
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    vertical-align: middle;
    margin-left: 0.5rem;
  }
  .past-program {
    opacity: 0.85;
  }
  @media (max-width: 700px) {
    .program-row {
      grid-template-columns: 1fr;
    }
    .program-img-placeholder {
      height: 180px;
    }
  }
</style>