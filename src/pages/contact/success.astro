---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Message Sent" description="Your message has been sent to People First Foundation.">
  <section class="page-header">
    <div class="container">
      <h1>Message Sent!</h1>
      <p>Thank you for reaching out to us.</p>
    </div>
  </section>
  <section class="section">
    <div class="container" style="text-align: center; max-width: 600px; margin: 0 auto;">
      <h2>We've received your message.</h2>
      <p>A member of our team will review it and get back to you as soon as possible. For urgent inquiries, feel free to call us directly.</p>
      <a href="/" class="btn btn-primary" style="margin-top: 1.5rem;">Return to Homepage</a>
    </div>
  </section>
</BaseLayout>