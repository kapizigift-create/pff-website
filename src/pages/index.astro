---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPrograms = await getCollection('programs');
const programs = allPrograms.filter((p) => p.data.active !== false);
programs.sort((a, b) => a.data.order - b.data.order);

const settingsEntries = await getCollection('siteSettings');
const settingsData = settingsEntries[0]?.data;

const dynamicStats = settingsData?.stats?.map((stat) => {
  if (stat.label === 'Core Programs Running') {
    return { number: String(programs.length), label: stat.label };
  }
  return stat;
}) || [
  { number: "32+", label: "Children at Umoza Academy" },
  { number: "Nationwide", label: "Birthing Kit Distribution" },
  { number: String(programs.length), label: "Core Programs Running" }
];
---

<BaseLayout title="Home" description="People First Foundation — Empowering vulnerable communities in Malawi through people-centered development.">

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="hero-tag">People First Foundation — Malawi</span>
      <h1>Putting People First,<br>Building Better Futures</h1>
      <p>We empower vulnerable children, women, and communities across Malawi through education, hygiene, skills development, and sustainable livelihoods.</p>
      <div class="hero-btns">
        <a href="/donate" class="btn btn-donate">Donate Now</a>
        <a href="/what-we-do" class="btn btn-secondary">Our Work</a>
      </div>
    </div>
  </section>

  <!-- Mission Snapshot -->
  <section class="section">
    <div class="container mission-grid">
      <div class="mission-text">
        <h2>Our Mission</h2>
        <p>To improve the quality of life of vulnerable and underserved communities through people-centered development initiatives that promote education, child protection, women and girl-child empowerment, skills development, social inclusion, and sustainable livelihoods.</p>
        <a href="/about" class="btn btn-secondary">Learn More About Us</a>
      </div>
      <div class="mission-cards">
        {dynamicStats.map((stat) => (
          <div class="impact-card">
            <span class="impact-number">{stat.number}</span>
            <span class="impact-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Programs Overview -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <h2>What We Do</h2>
        <p>Our programs are designed to restore dignity, create opportunity, and build self-reliance.</p>
      </div>
      <div class="program-grid">
        {programs.map((program) => (
          <div class="program-card">
            <div class="program-img placeholder-img">
              {program.data.image ? <img src={program.data.image} alt={program.data.name} /> : `Image: ${program.data.name}`}
            </div>
            <div class="program-info">
              <h3>{program.data.name}</h3>
              <p>{program.data.description.slice(0, 120)}...</p>
              <a href={`/what-we-do/${program.id}`}>Learn More →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Donate CTA -->
  <section class="cta-section">
    <div class="container cta-content">
      <h2>Your Support Changes Lives</h2>
      <p>Every contribution helps us feed a child, empower a mother, and restore dignity to a family in need across Malawi.</p>
      <a href="/donate" class="btn btn-donate">Make a Donation</a>
    </div>
  </section>

  <!-- Partners Strip -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <h2>Our Partners</h2>
        <p>We work alongside organisations that share our vision for a just and inclusive Malawi.</p>
      </div>
      <div class="partner-strip">
        <div class="partner-item placeholder-logo">Rafiki Foundation</div>
        <div class="partner-item placeholder-logo">Birthing Kit Foundation Australia</div>
      </div>
      <div style="text-align:center; margin-top:1rem;">
        <a href="/partners">View All Partners →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, #0d2f5c 100%);
    min-height: 85vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(200,150,62,0.15) 0%, transparent 60%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    color: white;
    max-width: 700px;
  }
  .hero-tag {
    display: inline-block;
    background: rgba(255,255,255,0.1);
    padding: 0.35rem 1rem;
    border-radius: 50px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1.5rem;
  }
  .hero h1 {
    color: white;
    margin-bottom: 1rem;
  }
  .hero p {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
  }
  .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero .btn-secondary {
    color: white;
    border-color: rgba(255,255,255,0.5);
  }
  .hero .btn-secondary:hover {
    background: white;
    color: var(--color-navy);
    border-color: white;
  }
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .mission-text h2 {
    margin-bottom: 1rem;
  }
  .mission-text p {
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
  }
  .mission-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .impact-card {
    background: var(--color-off-white);
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid var(--color-gold);
    display: flex;
    flex-direction: column;
  }
  .impact-number {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.8rem;
    color: var(--color-navy);
  }
  .impact-label {
    font-size: 0.9rem;
    color: var(--color-gray);
  }
  .section-heading {
    text-align: center;
    margin-bottom: 3rem;
  }
  .section-heading p {
    color: var(--color-gray);
    max-width: 550px;
    margin: 0.5rem auto 0;
  }
  .program-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .program-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .program-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }
  .program-img {
    height: 200px;
    background: var(--color-gray-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray);
    font-size: 0.85rem;
  }
  .program-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .program-info {
    padding: 1.5rem;
  }
  .program-info h3 {
    margin-bottom: 0.5rem;
  }
  .program-info p {
    font-size: 0.9rem;
    color: var(--color-gray);
    margin-bottom: 1rem;
  }
  .program-info a {
    font-weight: 600;
    font-size: 0.9rem;
  }
  .cta-section {
    background: linear-gradient(135deg, var(--color-gold) 0%, #d4a54a 100%);
    padding: 4rem 0;
    text-align: center;
  }
  .cta-content h2 {
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }
  .cta-content p {
    color: rgba(255,255,255,0.9);
    max-width: 500px;
    margin: 0 auto 1.5rem;
  }
  .cta-content .btn-donate {
    background: var(--color-navy);
  }
  .cta-content .btn-donate:hover {
    background: #0d2f5c;
  }
  .partner-strip {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .partner-item {
    background: var(--color-off-white);
    padding: 1.5rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    color: var(--color-gray);
    font-family: var(--font-heading);
  }
  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
    }
    .mission-grid {
      grid-template-columns: 1fr;
    }
    .program-grid {
      grid-template-columns: 1fr;
    }
  }
</style>