---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const newsItems = await getCollection('news');
  return newsItems.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<BaseLayout title={item.data.title} description={item.data.excerpt || item.data.title}>

  <section class="page-header">
    <div class="container">
      <span class="news-program-tag">{item.data.program}</span>
      <h1>{item.data.title}</h1>
      <p>{item.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
    </div>
  </section>

  <section class="section">
    <div class="container article-body">
      {item.data.image && <img src={item.data.image} alt={item.data.title} class="article-hero" />}
      <Content />
      <div style="margin-top:2rem;">
        <a href="/news">← Back to News & Stories</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .news-program-tag {
    display: inline-block;
    background: var(--color-gold);
    color: white;
    padding: 0.2rem 0.8rem;
    border-radius: 50px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }
  .article-body {
    max-width: 750px;
    margin: 0 auto;
  }
  .article-hero {
    width: 100%;
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  .article-body :global(p) {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.2rem;
  }
</style>